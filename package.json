{
	"name": "site",
	"description": "My minimalist portfolio site built with Vite, TailwindCSS and Github-Pages",
	"private": true,
	"homepage": "https://0xsarwagya.codes",
	"type": "module",
	"engines": {
		"node": "^22.8.0",
		"npm": "^10.8.2"
	},
	"volta": {
		"node": "22.8.0",
		"npm": "10.8.2"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"type:check": "tsc --noEmit",
		"lint": "biome check . --fix --unsafe",
		"lint:check": "biome ci .",
		"spell:check": "cspell \"{README.md,CODE_OF_CONDUCT.md,CONTRIBUTING.md,.github/*.md,src/**/*.tsx}\"",
		"cz": "cz",
		"audit": "better-npm-audit audit"
	},
	"dependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-social-icons": "^6.18.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@ryansonshine/commitizen": "^4.2.8",
		"@ryansonshine/cz-conventional-changelog": "^3.3.4",
		"@types/dotenv": "^8.2.0",
		"@types/node": "^22.7.3",
		"@types/prompts": "^2.4.9",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.3",
		"autoprefixer": "^10.4.20",
		"better-npm-audit": "3.11.0",
		"c8": "^10.1.2",
		"child_process": "^1.0.2",
		"cspell": "^8.14.4",
		"cz-conventional-changelog": "^3.3.0",
		"dotenv": "^16.4.5",
		"esbuild": "^0.23.1",
		"eslint": "^9.13.0",
		"gh-pages": "^6.2.0",
		"globals": "^15.11.0",
		"husky": "9.1.7",
		"lint-staged": "15.2.10",
		"postcss": "^8.4.49",
		"prompts": "^2.4.2",
		"rimraf": "^6.0.1",
		"slugify": "^1.6.6",
		"tailwindcss": "^3.4.15",
		"tailwindcss-animate": "1.0.7",
		"typescript": "~5.6.2",
		"typescript-eslint": "^8.11.0",
		"vite": "^5.4.10"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
